# Webhook: return raw + parsed JSON and skip validateAlert / placeOrder (payload inspection)
# WEBHOOK_SCHEMA_PROBE=true
# Local dev: auto-start ngrok and log "TradingView webhook URL" (requires full yarn install + ngrok authtoken)
# WEBHOOK_EXPOSE_NGROK=true
# NGROK_AUTHTOKEN=
# HTTP logging: logs inbound server req/res + outbound axios req/res
# Set false/0 to disable all HTTP logs
# HTTP_LOGGING_ENABLED=true
# Include request/response payload bodies in outbound axios logs
# HTTP_LOG_BODY_ENABLED=true

# Gains Network (gTrade)
# There is no Gains "API key": trading is wallet-signed; backend URLs are public (rate-limited).
# Use an EVM wallet on Arbitrum mainnet (production) or Arbitrum Sepolia (development/test).
# Network selector: mainnet | sepolia (sets chain/RPC/backend presets)
GAINS_NETWORK_NAME=sepolia
# Signing wallet private key (used to submit transactions). Legacy alias: GAINS_PRIVATE_KEY.
# In Render deployment, set this on worker service only.
GAINS_SIGNER_PRIVATE_KEY=
# Trader wallet address (optional). Leave empty for direct mode (uses signer address).
# Set this only for delegated mode / 1CT-style setup where signer != trader.
# GAINS_TRADER_ADDRESS=0x0000000000000000000000000000000000000000
# Default leverage multiplier (e.g. 10 for 10x). Legacy alias: GAINS_LEVERAGE
# Alert payload can override this per-order via: leverage, levrage, or Levrage.
GAINS_TRADE_LEVERAGE=10
# Optional: USDC (default), DAI, ETH, GNS. Legacy alias: GAINS_COLLATERAL
# GAINS_COLLATERAL_SYMBOL=USDC
# Optional per-field network overrides (win over GAINS_NETWORK_NAME and config/*.yaml)
# GAINS_RPC_HTTP_URL=
# GAINS_CHAIN_ID_DECIMAL=
# GAINS_BACKEND_HTTP_URL=
# Price slippage percent (0.05 => 5%). Legacy alias: GAINS_SLIPPAGE
# GAINS_PRICE_SLIPPAGE_PCT=0.05
# Optional referrer address. Legacy alias: GAINS_REFERRER
# GAINS_REFERRER_ADDRESS=0x0000000000000000000000000000000000000000
# After an open tx, async poll until the position appears in backend open-trades (logging only)
# GAINS_FILL_POLL_INTERVAL_MS=2000
# GAINS_FILL_WATCH_TIMEOUT_MS=120000
# Set GAINS_FILL_WATCH_TIMEOUT_MS=0 to disable polling

# Queue + worker (Redis/BullMQ)
# Docker compose default (api/worker container -> redis service):
REDIS_URL=redis://redis:6379
# Non-container local node process can override with:
# REDIS_URL=redis://127.0.0.1:6379
# ALERT_WORKER_CONCURRENCY=4
# ALERT_JOB_ATTEMPTS=5
# ALERT_JOB_BACKOFF_MS=1000
# ALERT_EXECUTION_LOCK_TTL_MS=120000

# Webhook HMAC security (optional but recommended in production)
# Signature format: sha256=<hex> over "${timestamp}.${rawBody}"
# WEBHOOK_HMAC_SECRET=
# WEBHOOK_REPLAY_WINDOW_MS=300000
# ALLOW_INSECURE_WEBHOOK_IN_PROD=true  # bypass production HMAC requirement (not recommended)

# Close reconciliation to handle backend eventual consistency
# GAINS_CLOSE_RECONCILE_RETRIES=4
# GAINS_CLOSE_RECONCILE_INTERVAL_MS=1500

# Observability
# METRICS_ENABLED=true

