# Webhook: return raw + parsed JSON and skip validateAlert / placeOrder (payload inspection)
# WEBHOOK_SCHEMA_PROBE=true

# Gains Network (gTrade)
# There is no Gains "API key": trading is wallet-signed; backend URLs are public (rate-limited).
# Use an EVM wallet on Arbitrum mainnet (production) or Arbitrum Sepolia (development/test).
GAINS_PRIVATE_KEY=
# Margin leverage (e.g. 10 for 10x). Position notional ≈ collateral * leverage.
GAINS_LEVERAGE=10
# Optional: USDC (default), DAI, ETH, GNS — must exist on the selected chain in @gainsnetwork/sdk
# GAINS_COLLATERAL=USDC
# Optional overrides (otherwise see config/*.yaml Gains section)
# GAINS_RPC_URL=
# GAINS_CHAIN_ID=
# GAINS_BACKEND_URL=
# GAINS_SLIPPAGE=0.05
# GAINS_REFERRER=0x0000000000000000000000000000000000000000
# After an open tx, async poll until the position appears in backend open-trades (logging only)
# GAINS_FILL_POLL_MS=2000
# GAINS_FILL_WATCH_MS=120000
# Set GAINS_FILL_WATCH_MS=0 to disable polling
