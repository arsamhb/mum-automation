{
	"name": "tradingview-alert-connector",
	"version": "1.0.0",
	"description": "Self-hosted webhook that receives TradingView alerts and executes trades on Gains Network (gTrade).",
	"homepage": "https://tv-connector.gitbook.io/docs/",
	"main": "index.js",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsc",
		"start:prod": "NODE_ENV=production node dist/index.js",
		"start": "tsc && NODE_ENV=production node dist/index.js",
		"start:worker": "tsc && NODE_ENV=production node dist/workers/alertsWorker.js",
		"start:test": "tsc && NODE_ENV=test ts-node dist/index.js",
		"start:dev": "tsc && NODE_ENV=development tsc-watch --onSuccess \"ts-node dist/index.js\"",
		"start:watch": "tsc && NODE_ENV=development tsc-watch --onSuccess \"node dist/index.js\"",
		"start:worker:watch": "tsc && NODE_ENV=development tsc-watch --onSuccess \"node dist/workers/alertsWorker.js\"",
		"test": "jest",
		"test:prod": "NODE_ENV=production jest",
		"ngrok": "ngrok http 3000",
		"ngrok:docker": "ngrok http 80"
	},
	"author": "0xIbuki",
	"license": "GPL-3.0-only",
	"dependencies": {
		"@gainsnetwork/sdk": "^1.8.8",
		"@sentry/integrations": "^6.19.1",
		"@sentry/node": "^6.18.2",
		"@sentry/tracing": "^6.18.2",
		"@types/config": "^0.0.41",
		"@types/express": "^4.17.13",
		"@types/node": "^20.10.0",
		"axios": "^1.6.7",
		"big.js": "6.1.1",
		"bullmq": "^5.53.2",
		"config": "^3.3.12",
		"dotenv": "^16.0.0",
		"ethers": "^5.7.2",
		"express": "^4.17.3",
		"helmet": "^5.0.2",
		"ioredis": "^5.8.1",
		"js-yaml": "^4.1.0",
		"node-json-db": "^1.4.1",
		"prom-client": "^15.1.3",
		"typescript": "^5.1.6"
	},
	"devDependencies": {
		"@types/jest": "^29.5.11",
		"@typescript-eslint/eslint-plugin": "^5.13.0",
		"@typescript-eslint/parser": "^5.13.0",
		"eslint": "^8.10.0",
		"eslint-config-prettier": "^8.4.0",
		"jest": "^29.7.0",
		"ngrok": "^4.3.0",
		"prettier": "2.5.1",
		"supertest": "^7.1.4",
		"ts-jest": "^29.1.1",
		"@types/supertest": "^6.0.3",
		"ts-node": "^10.5.0",
		"tsc-watch": "^4.6.0"
	}
}
